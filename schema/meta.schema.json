{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "meta.schema.json",
  "title": "Meta",
  "description": "赛事元信息",
  "type": "object",
  "required": ["eventName", "status"],
  "properties": {
    "eventName":  { "type": "string" },
    "edition":    { "type": "string" },
    "dungeon":    { "type": "string" },
    "boss":       { "type": "string" },
    "dataCenter": { "type": "string" },
    "startTime":  { "type": "string", "description": "ISO 8601 格式" },
    "status":     { "type": "string", "enum": ["upcoming", "live", "ended"] }
  },
  "additionalProperties": true
}
