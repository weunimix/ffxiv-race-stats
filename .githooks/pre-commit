#!/bin/sh
# ============================================================
# pre-commit — 提交前自动备份受保护的本地文件
#
# 受保护文件（仅存在于本地，不提交到远程）：
#   CLAUDE.md
#
# 备份位置：.git/safe/ （Git clean 无法触及）
# ============================================================

SAFE_DIR=".git/safe"
PROTECTED="CLAUDE.md"

mkdir -p "$SAFE_DIR"

for f in $PROTECTED; do
  if [ -f "$f" ]; then
    cp "$f" "$SAFE_DIR/$f"
  fi
done
